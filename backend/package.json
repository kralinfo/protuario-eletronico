{
  "name": "prontuario-eletronico-backend",
  "version": "1.0.0",
  "description": "API backend para prontuário eletrônico com arquitetura MVC",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "start:simple": "node src/server.js",
    "start:migrate": "npm run migrate:prod && node src/server.js",
    "start:ensure": "node ensure-abandono.cjs && node src/server.js",
    "start:legacy": "npm run migrate:smart && node src/server.js",
    "start:robust": "node migrate-robust.cjs && node src/server.js",
    "start:dev": "node src/server.js",
    "start:force-migrate": "npm run migrate:prod && node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:legacy": "nodemon src/index.js",
    "build": "npm install",
    "postbuild": "npm run auto-migrate",
    "test": "echo 'No tests specified' && exit 0",
    "lint": "echo 'No linting configured'",
    "check-env": "node check-env.js",
    "test-db": "node test-db-connection.js",
    "migrate": "node migrate.js",
    "migrate:prod": "npx knex migrate:latest --env production --knexfile knexfile.cjs",
    "migrate:smart": "node smart-migrate.cjs",
    "migrate:status": "npx knex migrate:status --env production --knexfile knexfile.cjs",
    "migrate:rollback": "npx knex migrate:rollback --env production --knexfile knexfile.cjs",
    "migrate:manual": "node migrate-production.cjs",
    "diagnose": "node diagnose-production.cjs",
    "force-abandono": "node force-abandono-migration.cjs",
    "robust-startup": "node robust-startup.cjs",
    "fix-production": "npm run robust-startup",
    "deep-debug": "node deep-debug.cjs",
    "create-abandono-sql": "node create-abandono-sql.cjs",
    "ensure-abandono": "node ensure-abandono.cjs",
    "diagnose-migrations": "node diagnose-migrations.cjs",
    "auto-migrate": "node auto-migrate.cjs",
    "fix-now": "node fix-now.cjs",
    "fix-all": "node fix-all-columns.cjs",
    "db:migrate": "npx knex migrate:latest",
    "db:rollback": "npx knex migrate:rollback",
    "db:status": "npx knex migrate:status",
    "db:make": "npx knex migrate:make",
    "db:seed": "npx knex seed:run",
    "db:reset": "npx knex migrate:rollback --all && npx knex migrate:latest",
    "migrate:dev": "npx knex migrate:latest --env development --knexfile knexfile.cjs",
    "migrate:dev:status": "npx knex migrate:status --env development --knexfile knexfile.cjs",
    "migrate:dev:rollback": "npx knex migrate:rollback --env development --knexfile knexfile.cjs",
    "update-db": "npm run migrate:dev",
    "check-migrations": "npm run migrate:dev:status",
    "setup": "node setup-dev.js",
    "test-setup": "node testar-setup.js",
    "migrate:robust": "node migrate-robust.cjs",
    "check:local": "node check-columns-local.cjs",
    "fix:migrations": "node migrate-robust.cjs",
    "db:sync": "node sync-db.cjs",
    "db:update": "node sync-db.cjs",
    "db:fix": "node sync-db.cjs",
    "sync": "node sync-db.cjs",
    "update": "node sync-db.cjs",
    "help": "node help-migrations.cjs",
    "migrations:help": "node help-migrations.cjs"
  },
  "keywords": [
    "prontuario",
    "eletronico",
    "api",
    "healthcare",
    "nodejs",
    "express"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "nodemailer": "^7.0.5",
    "pg": "^8.11.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
